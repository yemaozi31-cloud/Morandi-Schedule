{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Morandi Schedule",
  "version": "0.4.3",
  "identifier": "com.morandi.schedule",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "vite build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Morandi Schedule",
        "width": 1100,
        "height": 720,
        "minWidth": 400,
        "minHeight": 500,
        "center": true,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https:; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico", "icons/icon.png", "icons/icon.icns", "icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"],
    "targets": "all"
  },
  "plugins": {
    "notification": null,
    "globalShortcut": {},
    "autostart": null,
    "windowState": {},
    "shell": {},
    "clipboardManager": {}
  }
}
