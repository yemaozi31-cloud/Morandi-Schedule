{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Morandi Schedule",
  "version": "0.4.0",
  "identifier": "com.morandi.schedule",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "vite build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Morandi Schedule",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 500,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https: http:"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": "all"
  },
  "plugins": {
    "notification": {},
    "globalShortcut": {},
    "autostart": {},
    "windowState": {},
    "shell": {},
    "clipboardManager": {}
  }
}
